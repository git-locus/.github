# app.env.example – variabili runtime per il container Locus su Azure.
# Codifica in base64 e salva come secret APP_ENV_VARS_B64 in questa repo:
#   base64 -w0 app.env > tmp.b64   # Linux
#   base64 < app.env | tr -d '\n'  # macOS

# ── Next.js ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=/api/

# ── Dominio e TLS ─────────────────────────────────────────────────────────────
DOMAIN=<dominio pubblico della VM, es. locus.now>
LETS_ENCRYPT_EMAIL=<email per Let's Encrypt, es. ops@locus.now>

# ── Django ────────────────────────────────────────────────────────────────────
# genera con: openssl rand -base64 48
SECRET_KEY=changeme_generate_with_openssl_rand_base64_48
DJANGO_SETTINGS_MODULE=api.settings_prod
SERVER_HOST=<dominio pubblico, es. locus.now>
SERVER_URL=https://<dominio pubblico>

# ── JWT ───────────────────────────────────────────────────────────────────────
# genera con: openssl rand -base64 48
JWT_SECRET=changeme_generate_with_openssl_rand_base64_48

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_ENGINE=django.db.backends.postgresql
POSTGRES_NAME=<nome del database>
POSTGRES_USER=<username Azure PostgreSQL>
POSTGRES_PASSWORD=<password Azure PostgreSQL>
POSTGRES_HOST=<fqdn del server Azure PostgreSQL, es. locus-pg-xxxx.postgres.database.azure.com>
POSTGRES_PORT=5432

# ── Azure Blob Storage ────────────────────────────────────────────────────────
# Per Azure cloud (produzione): account + key.
AZURE_ACCOUNT_NAME=<nome dello storage account Azure>
AZURE_ACCOUNT_KEY=<chiave di accesso dello storage account Azure>
# In alternativa (es. Azurite in locale): connection string completa.
# Se valorizzata, ha priorità su AZURE_ACCOUNT_NAME/AZURE_ACCOUNT_KEY.
# AZURE_CONNECTION_STRING=DefaultEndpointsProtocol=...;BlobEndpoint=http://azurite:10000/devstoreaccount1;
