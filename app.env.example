# app.env.example – variabili runtime per il container Locus su Azure.
# Codifica in base64 e salva come secret APP_ENV_VARS_B64 in GitHub:
#   base64 -w0 app.env > tmp.b64   # Linux
#   base64 < app.env | tr -d '\n'  # macOS
#
# Il workflow aggiunge automaticamente POSTGRES_CONNECTION_STRING
# a partire dagli output Terraform, non serve includerla qui.

# Django
SECRET_KEY=changeme_generate_with_openssl_rand_base64_256
DJANGO_SETTINGS_MODULE=api.settings_prod
SERVER_HOST=<ip-o-dominio-della-vm>
SERVER_URL=http://<ip-o-dominio-della-vm>

# JWT (genera con: openssl rand -base64 256)
JWT_SECRET=changeme_generate_with_openssl_rand_base64_256

# Database (valori allineati a terraform.tfvars)
DATABASE_ENGINE=django.db.backends.postgresql
POSTGRES_NAME=appdb
POSTGRES_USER=<db_admin_username da tfvars>
POSTGRES_PASSWORD=<db_admin_password da tfvars>
# POSTGRES_HOST e POSTGRES_PORT vengono aggiunti dal workflow da terraform output
POSTGRES_HOST=<database_fqdn da terraform output>
POSTGRES_PORT=5432

# AWS S3 (se usi S3 reale in produzione)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-north-1
AWS_STORAGE_BUCKET_NAME=locus-general
AWS_THUMBNAILS_BUCKET_NAME=locus-thumbnails
